            "text": "<!DOCTYPE html><html lang=\"en\" class=\"__variable_f367f3 __variable_3cb7a3 h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/1f28520fcff3dcd3.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-0dc2bb3d23108052.js\"/><script src=\"/_next/static/chunks/4bd1b696-215e5051988c3dde.js\" async=\"\"></script><script src=\"/_next/static/chunks/794-5fb6eff04a716ab6.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-0a09489396c0edcf.js\" async=\"\"></script><script src=\"/_next/static/chunks/44530001-8f75776a0063f094.js\" async=\"\"></script><script src=\"/_next/static/chunks/500-c99b8dfd3de17c86.js\" async=\"\"></script><script src=\"/_next/static/chunks/845-550f2bce518d1a53.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-e5837ce0e6c7903c.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Clueboard — a daily trivia puzzle</title><meta name=\"description\" content=\"One board, one shot, every day. A daily trivia game in the spirit of classic TV trivia.\"/><link rel=\"icon\" href=\"/favicon.ico?603d046c9a6fdfbb\" type=\"image/x-icon\" sizes=\"16x16\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col bg-board text-white font-sans\"><div hidden=\"\"><!--$--><!--/$--></div><main class=\"flex-1 flex flex-col\"><header class=\"px-6 py-5 flex items-center justify-between\"><div class=\"font-serif text-2xl font-black text-gold-bright tracking-tight\">Clueboard</div><nav class=\"flex items-center gap-4 text-sm text-white/70\"><a class=\"hover:text-white\" href=\"/about\">About</a><a class=\"text-sm text-white/70 hover:text-white border border-white/20 px-3 py-1.5 rounded\" href=\"/login?next=%2Fplay\">Sign in</a></nav></header><section class=\"flex-1 flex flex-col items-center justify-center px-6 text-center max-w-3xl mx-auto\"><h1 class=\"font-serif font-black text-5xl sm:text-6xl text-gold-bright leading-tight mb-6\">A daily trivia puzzle.<br/>One board, one shot, every day.</h1><p class=\"font-serif text-2xl text-white/80 mb-10 max-w-xl leading-snug\">Six categories. Thirty clues. One Final Clue. Type your answers, build a score, and share your result. New board every day at midnight Eastern.</p><a class=\"inline-block bg-gold-bright text-board font-bold text-lg px-8 py-4 rounded-lg hover:brightness-110 transition shadow-lg\" href=\"/play\">Play today&#x27;s board</a><p class=\"text-sm text-white/50 mt-6\">No sign-in required.</p></section><footer class=\"px-6 py-8 text-xs text-white/50 text-center max-w-3xl mx-auto\"><p>Clues written by Claude AI, grounded in facts from<!-- --> <a class=\"underline hover:text-white\" href=\"https://opentdb.com\" target=\"_blank\" rel=\"noreferrer\">Open Trivia DB</a> <!-- -->(CC BY-SA 4.0) and<!-- --> <a class=\"underline hover:text-white\" href=\"https://the-trivia-api.com\" target=\"_blank\" rel=\"noreferrer\">The Trivia API</a> <!-- -->(CC BY 4.0). Clueboard is not affiliated with Sony Pictures Television or Jeopardy Productions, Inc.</p><p class=\"mt-3\"><a class=\"hover:text-white\" href=\"/about\">About</a></p></footer></main><!--$--><!--/$--><script src=\"/_next/static/chunks/webpack-0dc2bb3d23108052.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[7121,[],\\\"\\\"]\\n3:I[4581,[],\\\"\\\"]\\n4:I[8500,[\\\"730\\\",\\\"static/chunks/44530001-8f75776a0063f094.js\\\",\\\"500\\\",\\\"static/chunks/500-c99b8dfd3de17c86.js\\\",\\\"845\\\",\\\"static/chunks/845-550f2bce518d1a53.js\\\",\\\"974\\\",\\\"static/chunks/app/page-e5837ce0e6c7903c.js\\\"],\\\"\\\"]\\n6:I[484,[],\\\"OutletBoundary\\\"]\\n7:\\\"$Sreact.suspense\\\"\\n9:I[484